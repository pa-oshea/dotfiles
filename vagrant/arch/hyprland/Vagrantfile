# -*- mode: ruby -*-
# vi: set ft=ruby :

Vagrant.configure("2") do |config|
  # Use Arch Linux box that supports libvirt
  config.vm.box = "generic/arch"
  config.vm.box_check_update = true
  
  # Set VM hostname
  config.vm.hostname = "arch-vagrant-hyprland"
  
  # Share your dotfiles directory for easy testing
  config.vm.synced_folder "~/.dotfiles", "/home/vagrant/.dotfiles", type: "9p", accessmode: "mapped"
  
  # Configure libvirt provider for optimal performance
  config.vm.provider "libvirt" do |libvirt|
    # Resource allocation (adjust based on your host specs)
    libvirt.memory = 12288  # 12GB RAM
    libvirt.cpus = 8        # 8 CPU cores
    
    # VM identification
    libvirt.title = "Arch Linux Hyprland Dotfiles Test Environment"
    libvirt.description = "Arch Linux VM for testing dotfiles with Hyprland (Wayland)"
    
    # Graphics and display configuration for Wayland (3D acceleration required for Hyprland)
    libvirt.graphics_type = "spice"
    libvirt.graphics_autoport = "yes"
    libvirt.graphics_passwd = nil  # No password for easier access
    libvirt.video_type = "virtio"
    libvirt.video_vram = 131072    # 128MB video memory
    libvirt.video_accel3d = "yes"  # Required for Hyprland in VMs
    
    # Enable OpenGL acceleration (required for Hyprland)
    libvirt.graphics_gl = "yes"
    
    # Audio configuration
    libvirt.sound_type = "ich9"
    
    # Spice agent for better desktop integration
    libvirt.channel :type => 'spicevmc', :target_name => 'com.redhat.spice.0', :target_type => 'virtio'
    libvirt.channel :type => 'unix', :target_name => 'org.qemu.guest_agent.0', :target_type => 'virtio'
    
    # Performance optimizations
    libvirt.nested = true                    # Enable nested virtualization
    libvirt.cpu_mode = 'host-passthrough'   # Best CPU performance
    libvirt.machine_type = "q35"            # Modern machine type
    libvirt.disk_bus = "virtio"             # Faster disk I/O
    libvirt.nic_model_type = "virtio"       # Faster network
    
    # Random number generator for better entropy
    libvirt.random :model => 'random'
    
    # Additional storage if needed (uncomment to add a 50GB data disk)
    # libvirt.storage :file, :size => '50G', :type => 'qcow2', :bus => 'virtio'
    
    # USB redirection for better hardware support
    libvirt.usb_controller :model => 'nec-xhci', :ports => 8
    
    # Memory balloon for dynamic memory management
    libvirt.memorybacking :access, :mode => "shared"
  end
  
  # Pre-provision setup (runs before main provisioning)
  config.vm.provision "shell", name: "pre-setup", inline: <<-SHELL
    echo "🔧 Pre-setup: Optimizing pacman and fixing keyrings..."
    
    # Optimize pacman configuration
    sed -i 's/#ParallelDownloads = 5/ParallelDownloads = 10/' /etc/pacman.conf
    sed -i 's/#Color/Color/' /etc/pacman.conf
    sed -i 's/#VerbosePkgLists/VerbosePkgLists/' /etc/pacman.conf
    
    # Enable multilib repository for broader package support
    if ! grep -q "\\[multilib\\]" /etc/pacman.conf; then
      echo -e "\n[multilib]\nInclude = /etc/pacman.d/mirrorlist" >> /etc/pacman.conf
    fi
    
    # Fix keyring issues (common Arch Linux VM problem)
    pacman-key --init
    pacman-key --populate archlinux
    pacman -Sy --noconfirm archlinux-keyring
    
    # Update package database
    pacman -Sy
  SHELL
  
  # Main system provisioning
  config.vm.provision "shell", name: "system-setup", inline: <<-SHELL
    echo "📦 Installing base system packages..."
    
    # System update with retry logic
    for i in {1..3}; do
      if pacman -Syu --noconfirm; then
        break
      else
        echo "Update attempt $i failed, retrying..."
        sleep 5
      fi
    done
    
    # Essential development tools
    pacman -S --noconfirm --needed \
      base-devel \
      git \
      wget \
      curl \
      unzip \
      vim \
      nano \
      htop \
      neofetch \
      tree \
      which \
      sudo \
      jq
    
    echo "✅ Base system packages installed"
  SHELL
  
  # Wayland and Hyprland installation
  config.vm.provision "shell", name: "wayland-hyprland", inline: <<-SHELL
    echo "🚗 Installing Wayland and Hyprland..."
    
    # Core Wayland components
    pacman -S --noconfirm --needed \
      wayland \
      wayland-protocols \
      mesa \
      mesa-utils \
      libva-mesa-driver \
      vulkan-mesa-driver
    
    # Hyprland and essential components
    pacman -S --noconfirm --needed \
      hyprland \
      xdg-desktop-portal-hyprland \
      qt5-wayland \
      qt6-wayland \
      xorg-xwayland
    
    # Display manager with Wayland support
    pacman -S --noconfirm --needed \
      greetd \
      greetd-tuigreet
    
    # SPICE guest tools and VM integration
    pacman -S --noconfirm --needed \
      spice-vdagent \
      qemu-guest-agent
    
    echo "✅ Wayland and Hyprland installed"
  SHELL
  
  # Essential GUI applications for Hyprland/Wayland
  config.vm.provision "shell", name: "wayland-apps", inline: <<-SHELL
    echo "🎨 Installing Hyprland-compatible GUI applications..."
    
    # Core Wayland applications (Hyprland-specific choices)
    pacman -S --noconfirm --needed \
      wofi \
      waybar \
      foot \
      kitty \
      alacritty \
      firefox \
      thunar \
      grim \
      slurp \
      wl-clipboard \
      mako \
      dunst \
      imv \
      mpv \
      ranger \
      pavucontrol \
      swaylock-effects \
      swayidle \
      swaybg
    
    # Additional useful tools for Hyprland
    pacman -S --noconfirm --needed \
      networkmanager \
      network-manager-applet \
      bluez \
      bluez-utils \
      brightnessctl \
      playerctl \
      wdisplays \
      blueman \
      lxappearance \
      polkit-gnome \
      xdg-desktop-portal-gtk \
      gammastep \
      wlogout \
      hypridle \
      hyprlock \
      hyprpaper \
      hyprshot
    
    echo "✅ Hyprland applications installed"
  SHELL
  
  # Audio system setup
  config.vm.provision "shell", name: "audio-setup", inline: <<-SHELL
    echo "🔊 Setting up audio system..."
    
    # Install PipeWire audio stack (works great with Wayland)
    pacman -S --noconfirm --needed \
      pipewire \
      pipewire-pulse \
      pipewire-alsa \
      pipewire-jack \
      wireplumber \
      alsa-utils \
      pamixer
    
    echo "✅ Audio system configured"
  SHELL
  
  # Fonts and theming
  config.vm.provision "shell", name: "fonts-themes", inline: <<-SHELL
    echo "🎭 Installing fonts and themes..."
    
    # Essential fonts including JetBrains Mono Nerd Font
    pacman -S --noconfirm --needed \
      ttf-dejavu \
      ttf-liberation \
      noto-fonts \
      noto-fonts-emoji \
      ttf-font-awesome \
      ttf-fira-code \
      ttf-fira-sans \
      ttf-jetbrains-mono \
      ttf-jetbrains-mono-nerd \
      ttf-meslo-nerd
    
    # Additional fonts for better coverage
    pacman -S --noconfirm --needed \
      adobe-source-code-pro-fonts \
      inter-font \
      cantarell-fonts
    
    # GTK themes and icons (still used by some Wayland apps)
    pacman -S --noconfirm --needed \
      gtk3 \
      gtk4 \
      adwaita-icon-theme \
      papirus-icon-theme \
      arc-gtk-theme \
      arc-icon-theme \
      breeze \
      breeze-gtk
    
    echo "✅ Fonts and themes installed"
  SHELL
  
  # Vagrant user setup and configuration
  config.vm.provision "shell", name: "vagrant-user-setup", inline: <<-SHELL
    echo "👤 Setting up vagrant user for Hyprland environment..."
    
    # Ensure vagrant user is in all necessary groups
    usermod -aG wheel,audio,video,input,storage vagrant
    echo "✅ Added vagrant user to necessary groups"
    
    # Set up basic shell and Wayland session for vagrant user
    sudo -u vagrant bash -c '
      # Create basic directories
      mkdir -p ~/.config ~/.local/bin ~/.local/share
      mkdir -p ~/.config/hypr ~/.config/waybar ~/.config/wofi ~/.config/foot ~/.config/kitty ~/.config/alacritty ~/.config/mako ~/.config/dunst
      echo "✅ Created user directories"
    '
    
    # Set proper ownership for vagrant user files
    chown -R vagrant:vagrant /home/vagrant
    chmod 755 /home/vagrant
    
    echo "✅ Vagrant user configuration completed"
  SHELL
  
  # Create minimal Hyprland config for VM compatibility
  config.vm.provision "shell", name: "hyprland-config", inline: <<-SHELL
    echo "🚗 Creating VM-compatible Hyprland configuration..."
    
    sudo -u vagrant bash -c '
      mkdir -p ~/.config/hypr
      cat > ~/.config/hypr/hyprland.conf << "EOF"
# VM-optimized Hyprland configuration

# Monitor configuration (auto-detect VM display)
monitor=,preferred,auto,1

# Disable problematic features for VMs
misc {
    disable_hyprland_logo = true
    disable_splash_rendering = true
    force_default_wallpaper = 0
    vfr = false
}

# Input configuration
input {
    kb_layout = us
    follow_mouse = 1
    sensitivity = 0
    accel_profile = flat
}

# General settings (VM-optimized)
general {
    gaps_in = 2
    gaps_out = 5
    border_size = 1
    col.active_border = rgba(33ccffee)
    col.inactive_border = rgba(595959aa)
    layout = dwindle
    allow_tearing = false
}

# Minimal decoration (reduce GPU load)
decoration {
    rounding = 5
    blur {
        enabled = false
        size = 3
        passes = 1
        new_optimizations = true
    }
    drop_shadow = false
    shadow_range = 4
    shadow_render_power = 3
    col.shadow = rgba(1a1a1aee)
}

# Disable animations for better VM performance
animations {
    enabled = false
}

# Layout configuration
dwindle {
    pseudotile = true
    preserve_split = true
    smart_split = false
    smart_resizing = false
}

# Window rules
windowrule = float, ^(pavucontrol)$
windowrule = float, ^(blueman-manager)$

# Key bindings
$mainMod = SUPER

# Basic bindings
bind = $mainMod, Q, exec, foot
bind = $mainMod, Return, exec, foot
bind = $mainMod, C, killactive,
bind = $mainMod, M, exit,
bind = $mainMod, E, exec, thunar
bind = $mainMod, V, togglefloating,
bind = $mainMod, R, exec, wofi --show drun
bind = $mainMod, P, pseudo,
bind = $mainMod, J, togglesplit,

# Move focus with vim keys
bind = $mainMod, h, movefocus, l
bind = $mainMod, l, movefocus, r
bind = $mainMod, k, movefocus, u
bind = $mainMod, j, movefocus, d

# Move focus with arrow keys
bind = $mainMod, left, movefocus, l
bind = $mainMod, right, movefocus, r
bind = $mainMod, up, movefocus, u
bind = $mainMod, down, movefocus, d

# Switch workspaces
bind = $mainMod, 1, workspace, 1
bind = $mainMod, 2, workspace, 2
bind = $mainMod, 3, workspace, 3
bind = $mainMod, 4, workspace, 4
bind = $mainMod, 5, workspace, 5
bind = $mainMod, 6, workspace, 6
bind = $mainMod, 7, workspace, 7
bind = $mainMod, 8, workspace, 8
bind = $mainMod, 9, workspace, 9
bind = $mainMod, 0, workspace, 10

# Move active window to workspace
bind = $mainMod SHIFT, 1, movetoworkspace, 1
bind = $mainMod SHIFT, 2, movetoworkspace, 2
bind = $mainMod SHIFT, 3, movetoworkspace, 3
bind = $mainMod SHIFT, 4, movetoworkspace, 4
bind = $mainMod SHIFT, 5, movetoworkspace, 5
bind = $mainMod SHIFT, 6, movetoworkspace, 6
bind = $mainMod SHIFT, 7, movetoworkspace, 7
bind = $mainMod SHIFT, 8, movetoworkspace, 8
bind = $mainMod SHIFT, 9, movetoworkspace, 9
bind = $mainMod SHIFT, 0, movetoworkspace, 10

# Mouse bindings
bindm = $mainMod, mouse:272, movewindow
bindm = $mainMod, mouse:273, resizewindow

# Environment variables for VMs (with 3D acceleration)
env = WLR_NO_HARDWARE_CURSORS,1

# Auto-start applications
exec-once = waybar
exec-once = mako
EOF
    '
    
    echo "✅ VM-compatible Hyprland config created"
  SHELL
  config.vm.provision "shell", name: "services", inline: <<-SHELL
    echo "⚙️ Configuring system services for Hyprland..."
    
    # Enable essential services
    systemctl enable greetd
    systemctl enable NetworkManager
    systemctl enable bluetooth
    
    # Configure greetd with tuigreet and auto-login for vagrant user
    cat > /etc/greetd/config.toml << 'EOF'
      [terminal]
      vt = 1

      [default_session]
      command = "tuigreet --time --remember --remember-user-session --asterisks --cmd Hyprland"
      user = "greeter"

      [initial_session]
      command = "Hyprland"
      user = "vagrant"
      EOF
    
    # Create systemd user service directory for vagrant
    sudo -u vagrant mkdir -p /home/vagrant/.config/systemd/user
    
    # Set up environment variables for Wayland session (with 3D acceleration)
    sudo -u vagrant bash -c '
      cat > ~/.pam_environment << "EOF"
        MOZ_ENABLE_WAYLAND=1
        QT_QPA_PLATFORM=wayland
        QT_WAYLAND_DISABLE_WINDOWDECORATION=1
        GDK_BACKEND=wayland
        XDG_CURRENT_DESKTOP=Hyprland
        XDG_SESSION_DESKTOP=Hyprland
        XDG_SESSION_TYPE=wayland
        WLR_NO_HARDWARE_CURSORS=1
        HYPRLAND_LOG_WLR=1
        EOF
    '
    
    echo "✅ Services configured with auto-login for vagrant user"
  SHELL
  
  # Final setup and information
  config.vm.provision "shell", name: "final-setup", inline: <<-SHELL
    echo "🎯 Final setup and optimizations..."
    
    # Update font cache
    fc-cache -fv
    
    # Update desktop database
    update-desktop-database
    
    # Create Pictures directory for screenshots
    sudo -u vagrant mkdir -p /home/vagrant/Pictures
    
    # Clean package cache to save space
    pacman -Sc --noconfirm

    echo ""
    echo "🚗 ==============================================="
    echo "🚗  ARCH LINUX HYPRLAND DOTFILES TEST VM READY!"
    echo "🚗 ==============================================="
    echo ""
    echo "📋 VM Information:"
    echo "   • Hostname: arch-vagrant-hyprland"
    echo "   • Username: vagrant (auto-login enabled)"
    echo "   • Desktop: Hyprland (Wayland)"
    echo "   • Dotfiles location: ~/.dotfiles"
    echo ""
    echo "🚀 Next Steps:"
    echo "   1. Reboot the VM: vagrant reload"
    echo "   2. Access GUI via virt-viewer (recommended for Wayland)"
    echo "   3. Or use: vagrant ssh (text-based access)"
    echo "   4. Configure Hyprland in ~/.config/hypr/hyprland.conf"
    echo ""
    echo "💡 Your dotfiles are mapped to:"
    echo "   • Host directory → VM: ~/.dotfiles"
    echo "   • Any changes on host are immediately visible in VM"
    echo ""
    echo "📁 Standard Hyprland config locations:"
    echo "   • Hyprland config: ~/.config/hypr/hyprland.conf"
    echo "   • Waybar config: ~/.config/waybar/config"
    echo "   • Wofi: ~/.config/wofi/"
    echo "   • Foot terminal: ~/.config/foot/foot.ini"
    echo "   • Kitty terminal: ~/.config/kitty/kitty.conf"
    echo "   • Alacritty: ~/.config/alacritty/alacritty.toml"
    echo "   • Mako notifications: ~/.config/mako/config"
    echo "   • Dunst notifications: ~/.config/dunst/dunstrc"
    echo ""
    echo "🚗 Hyprland-specific features:"
    echo "   • Screenshots: grim (full) / grim -g \"\$(slurp)\" (area) / hyprshot"
    echo "   • Clipboard: wl-copy / wl-paste"
    echo "   • Display config: wdisplays or hyprctl monitors"
    echo "   • App launcher: wofi (instead of dmenu/rofi)"
    echo "   • Status bar: waybar (instead of polybar)"
    echo "   • Notifications: mako or dunst"
    echo "   • Terminal: foot (native Wayland), kitty, or alacritty"
    echo "   • Screen lock: hyprlock (instead of swaylock)"
    echo "   • Idle management: hypridle (instead of swayidle)"
    echo "   • Wallpaper: hyprpaper (instead of swaybg)"
    echo "   • Session logout: wlogout"
    echo ""
    echo "📱 Environment variables set:"
    echo "   • MOZ_ENABLE_WAYLAND=1 (Firefox Wayland support)"
    echo "   • QT_QPA_PLATFORM=wayland"
    echo "   • GDK_BACKEND=wayland"
    echo "   • XDG_SESSION_TYPE=wayland"
    echo "   • XDG_CURRENT_DESKTOP=Hyprland"
    echo "   • HYPRLAND_LOG_WLR=1 (for debugging)"
    echo ""
    echo "🔧 Hyprland Control Commands:"
    echo "   • hyprctl monitors (list monitors)"
    echo "   • hyprctl workspaces (list workspaces)"
    echo "   • hyprctl clients (list windows)"
    echo "   • hyprctl reload (reload config)"
    echo "   • hyprctl keyword [setting] [value] (change setting)"
    echo ""
  SHELL
end
