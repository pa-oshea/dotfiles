
# =============================================================================
# ALIASES
# =============================================================================

# -----------------------------------------------------------------------------
# Quick shortcuts
# -----------------------------------------------------------------------------
alias lg="lazygit"
alias ld="lazydocker"
alias q="exit"

# -----------------------------------------------------------------------------
# Directory navigation
# -----------------------------------------------------------------------------
alias dev="cd $DEV_HOME"
alias work="cd $WORK_HOME"
alias dots="cd $XDG_CONFIG_HOME"

# -----------------------------------------------------------------------------
# Config editing
# -----------------------------------------------------------------------------
alias zshconfig="$EDITOR $ZDOTDIR/.zshrc"
alias zshenv="$EDITOR ~/.zshenv"
alias starconfig="$EDITOR $STARSHIP_CONFIG"

# -----------------------------------------------------------------------------
# File listing
# -----------------------------------------------------------------------------
alias ll="eza -la --git --icons --group-directories-first"
alias la="eza -la --git --icons --group-directories-first"
alias ls="eza -la --git --icons --group-directories-first"
alias lt="eza -T --git --icons --level=2"
alias lt2="eza -T --git --icons --level=2"
alias lt3="eza -T --git --icons --level=3"

# -----------------------------------------------------------------------------
# Modern CLI replacements
# -----------------------------------------------------------------------------
alias dust="dust -r"
alias ps="procs"

# -----------------------------------------------------------------------------
# System monitoring
# -----------------------------------------------------------------------------
alias df="df -h"
alias du="du -sh"
alias ports="ss -tuln"
alias listening="ss -tlnp"
alias sysinfo="fastfetch"
alias neofetch="fastfetch"
alias usage="dust -d 1"
alias meminfo="btm --memory"

# -----------------------------------------------------------------------------
# JSON/YAML processing
# -----------------------------------------------------------------------------
alias json="fx"
alias yaml="yq"
alias pretty="jq ."
alias prettyyml="yq . -P"

# -----------------------------------------------------------------------------
# Development workflow
# -----------------------------------------------------------------------------
alias bench="hyperfine"
alias loc="tokei"
alias api="atac"

# -----------------------------------------------------------------------------
# Network and HTTP
# -----------------------------------------------------------------------------
alias http="http --print=HhBb"
alias https="http --print=HhBb https://"
alias curl="curl -w '\n'"

# -----------------------------------------------------------------------------
# File management
# -----------------------------------------------------------------------------
alias fm="yazi"

# -----------------------------------------------------------------------------
# Documentation and help
# -----------------------------------------------------------------------------
alias cheat="navi"
alias tldr="tldr --color always"

# -----------------------------------------------------------------------------
# Kubernetes
# -----------------------------------------------------------------------------
alias k9="k9s"
alias kube="kubectl"

# -----------------------------------------------------------------------------
# Container management
# -----------------------------------------------------------------------------
alias dps="docker ps --format 'table {{.Names}}\t{{.Status}}\t{{.Ports}}'"
alias dlogs="docker logs -f"
alias dexec="docker exec -it"
alias dimg="docker images --format 'table {{.Repository}}\t{{.Tag}}\t{{.Size}}'"

# -----------------------------------------------------------------------------
# Clipboard (Wayland — wl-clipboard)
# -----------------------------------------------------------------------------
alias clip="wl-copy"
alias paste="wl-paste"

# -----------------------------------------------------------------------------
# File watching and automation
# -----------------------------------------------------------------------------
# NOTE: 'watch' is intentionally not aliased — the Nix 'watch -c' flag
# conflicts with system watch on some tools. Use the full command when needed.
alias autorun="entr -c"
alias parallel="parallel --will-cite"

# -----------------------------------------------------------------------------
# Shell utilities
# -----------------------------------------------------------------------------
alias reload="source $ZDOTDIR/.zshrc"
alias path="echo $PATH | tr ':' '\n'"
alias envs="env | sort"           # 'env' itself is a command — use 'envs'

# -----------------------------------------------------------------------------
# Markdown viewing
# -----------------------------------------------------------------------------
alias md="glow"
alias readme="glow README.md"
alias mdprev="glow -p"

# -----------------------------------------------------------------------------
# Ripgrep
# -----------------------------------------------------------------------------
alias rgf='rg --files'
alias rgi='rg --ignore-case'
alias rgw='rg --word-regexp'
alias rgt='rg --type'
alias rgv='rg --invert-match'
alias rgc='rg --count'
alias rgl='rg --files-with-matches'
alias rgtodo='rg -i "todo|fixme|hack|xxx"'
alias rgconf='rg --type config'

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------
alias sqlite="sqlite3"
alias db="sqlite3"

# -----------------------------------------------------------------------------
# Code quality
# -----------------------------------------------------------------------------
alias shellcheck="shellcheck -f gcc"
alias yamllint="yamllint -f parsable"

# -----------------------------------------------------------------------------
# Just
# -----------------------------------------------------------------------------
alias j="just"
alias jl="just --list"
alias jr="just --dry-run"

# -----------------------------------------------------------------------------
# Mise
# -----------------------------------------------------------------------------
alias mr="mise run"
alias ml="mise list"
alias mi="mise install"
alias mu="mise upgrade"

# -----------------------------------------------------------------------------
# fzf utilities
# -----------------------------------------------------------------------------
alias fh='history | fzf --tac --no-sort | sed "s/ *[0-9]* *//" | tr -d "\n" | wl-copy'
alias fcd='cd $(fd -t d | fzf --preview "eza -la {}")'
alias fkill='ps -ef | fzf --header-lines=1 | awk "{print \$2}" | xargs kill -9'
alias fenv='env | fzf | cut -d= -f1'
alias ff='fd -t f | fzf'

